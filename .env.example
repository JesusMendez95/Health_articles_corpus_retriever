# Copia este archivo como .env y rellena tus credenciales
# cp .env.example .env

# Email para la API de Unpaywall (gratuita, solo se usa para identificación)
UNPAYWALL_EMAIL=tu@email.com

# Credenciales de Consensus (necesario para extraer Study Snapshots)
CONSENSUS_EMAIL=tu@email.com
CONSENSUS_PASSWORD=tu_contraseña
